# Copy this file to .env and fill in values. .env is gitignored.

# Required for the Tavily web search tool.
TAVILY_API_KEY=

# Optional: raises Hugging Face rate limits / enables gated models (e.g. Llama).
# HF_TOKEN=

# Optional overrides (defaults shown).
# Any transformers-format (safetensors) chat model works; GGUF-only repos do
# not - those are llama.cpp files that AutoModelForCausalLM can't load. Size
# the model to your VRAM: weights alone need roughly 2 GB per billion params
# at fp16/bf16.
# VISH_MODEL_NAME=Qwen/Qwen2.5-1.5B-Instruct
# VISH_MODEL_DEVICE=auto
# The model is loaded from the local cache automatically when present, with
# no manual flag needed. Set this to true to make a cache hit mandatory
# (error instead of downloading) - useful once you're fully offline.
# VISH_MODEL_LOCAL_FILES_ONLY=false
# VISH_LOG_DIR=./logs
# VISH_CLASSIFIER_TEMPERATURE=0.0
# VISH_ORCHESTRATOR_TEMPERATURE=0.1
# VISH_RESPONSE_TEMPERATURE=0.7
# VISH_FUZZY_MATCH_THRESHOLD=60
# VISH_NWS_USER_AGENT=vish-agent-research-project (contact: you@example.com)
# VISH_HTTP_TIMEOUT_SECONDS=10
